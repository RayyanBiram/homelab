# ProtonVPN OpenVPN credentials
# Get from: account.proton.me → Account → OpenVPN / IKEv2 username
VPN_USER=your_protonvpn_openvpn_username
VPN_PASS=your_protonvpn_openvpn_password

# Cloudflare Tunnel token
# Get from: dash.cloudflare.com → Zero Trust → Networks → Tunnels
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
