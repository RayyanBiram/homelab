# Immich Environment Variables
# Copy this file to immich.env and fill in your real values
# Never commit immich.env to git — only this .example file

DB_HOSTNAME=immich_postgres
DB_USERNAME=immich
DB_PASSWORD=change_this_to_a_strong_password
DB_DATABASE_NAME=immich
REDIS_HOSTNAME=immich_redis
UPLOAD_LOCATION=/mnt/nas/photos
